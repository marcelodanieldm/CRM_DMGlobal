# ─────────────────────────────────────────────────────────────────────────────
# CRM DMGlobal — Variables de entorno
# Copiar a .env y completar con los valores reales.
# Nunca commitear el .env al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core FastAPI ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./dmglobal_dev.db
JWT_SECRET_KEY=cambia-esto-por-una-clave-de-al-menos-50-caracteres
JWT_EXPIRY_MINUTES=480
BOT_API_KEY=clave-para-validacion-de-bots-internos

# ── Pasarelas de pago ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────────────────────────────────────
# Recepcionista Virtual Nocturno
# ─────────────────────────────────────────────────────────────────────────────

# URL base del CRM Django (dm_global) para consultas de contexto del cliente.
# En producción: https://tu-dominio.com
CRM_DM_GLOBAL_API_URL=http://localhost:8001

# API Key estática que el Recepcionista usa al llamar a los endpoints
# protegidos del CRM Django. Configurar en dm_global/.env como la misma clave.
CRM_DM_GLOBAL_API_KEY=

# ID del hotel/comercio tal como está registrado en el CRM DM Global.
# Formato: TIPO-NOMBRE-NN  (ej: HOTEL-TERRAZAS-01, TOUR-PATAGONIA-02)
# Se usa para verificar que la suscripción al Recepcionista Virtual está activa.
CRM_HOTEL_ID=HOTEL-MI-ESTABLECIMIENTO-01

# Google Gemini Flash
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Google Drive — carpeta que contiene los PDFs de contexto del hotel
# (tarifas, políticas, menú, actividades, etc.)
# Formato: ID de la carpeta en la URL de Drive (la parte después de /folders/)
GOOGLE_DRIVE_FOLDER_ID=

# ── Google Sheets — registro de huéspedes ────────────────────────────────────
# ID del Spreadsheet de gestión de huéspedes (URL: .../spreadsheets/d/{ID}/edit)
GOOGLE_SHEETS_ID=
# Nombre de la pestaña con los datos de huéspedes
GOOGLE_SHEETS_TAB=Huéspedes
# ID del PDF principal de reglas del hotel (alternativa a usar una carpeta completa)
# URL del archivo en Drive: https://drive.google.com/file/d/{FILE_ID}/view
GOOGLE_DRIVE_FILE_ID=

# Path al archivo JSON de la cuenta de servicio de Google Cloud
# (necesario para descargar archivos de Drive sin intervención humana)
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service-account.json

# ── WhatsApp Business Cloud API (Meta) ───────────────────────────────────────
# Token de verificación que Meta envía al configurar el webhook.
# Puede ser cualquier string secreto; debe coincidir con lo configurado en
# Meta for Developers → App → WhatsApp → Configuration → Verify Token.
WHATSAPP_VERIFY_TOKEN=

# Token de acceso permanente de la app de Meta.
# Obtener en: Meta for Developers → App → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=

# ID del número de teléfono de WhatsApp Business (no el número en sí,
# sino el ID numérico que aparece en la consola de Meta).
WHATSAPP_PHONE_NUMBER_ID=

# ── Pre-Check-In ─────────────────────────────────────────────────────────────
# URL del formulario donde el huésped sube DNI/Pasaporte antes de llegar
PRECHECKIN_FORM_URL=https://tu-crm.com/precheckin/

# ── Comportamiento del Recepcionista ─────────────────────────────────────────
# Nombre del hotel/comercio que el Recepcionista representa.
RECEPTIONIST_BUSINESS_NAME=Hotel DM Global

# Idioma por defecto para respuestas (es | en | pt | fr | de)
RECEPTIONIST_DEFAULT_LANG=es

# Máximo de turnos de conversación que el Recepcionista recuerda por sesión.
RECEPTIONIST_MAX_HISTORY=10

# Tiempo en minutos antes de que una sesión de conversación expire.
RECEPTIONIST_SESSION_TTL_MINUTES=60
